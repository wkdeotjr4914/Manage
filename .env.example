# AWS PostgreSQL 연결 문자열 (실제 값으로 .env 에 채워 넣으세요)
# 형식: postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>?schema=public
# 예)  postgresql://appuser:secret@my-db.abc123.ap-northeast-2.rds.amazonaws.com:5432/second_brain?schema=public
#
# SSL 이 필요한 RDS 라면 끝에 &sslmode=require 를 추가하세요.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/second_brain?schema=public&sslmode=require"

# Google Gemini API 키 — 문서 임포트 AI 분석(/import)에 사용.
# https://aistudio.google.com/apikey 에서 발급한 키를 넣으세요. 미설정 시 규칙 기반 모드만 동작합니다.
GEMINI_API_KEY="AIza..."
# 선택: 사용할 모델 (기본값 gemini-flash-lite-latest)
# IMPORT_AI_MODEL="gemini-flash-lite-latest"

# 세션 쿠키 HMAC 서명 시크릿 (16자 이상, 필수). 아래로 새로 생성:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="change-me-generate-a-long-random-string"

# 선택: 초기 관리자 계정 부트스트랩 (npm run db:seed:admin)
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="8자-이상-비밀번호"
# SEED_ADMIN_NAME="관리자"

# 구글 연동(사용자별 OAuth 2.0) — Gmail 수집 · Calendar 내보내기 · Sheets 리포트.
# ※ 앱 자격증명은 이제 관리자(ADMIN)가 앱 안에서 설정합니다:
#   /settings/integrations → "구글 OAuth 앱 설정 (관리자)" 카드 (DB에 암호화 저장, 재시작 불필요).
# 아래 GOOGLE_* 는 그 DB 설정이 없을 때만 쓰이는 폴백입니다(배포 환경변수 주입용, 선택).
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보에서 "OAuth 클라이언트 ID"
# (유형: 웹 애플리케이션)를 만들고, 승인된 리디렉션 URI에 REDIRECT_URI를 등록하세요.
# 또한 Gmail/Google Calendar/Google Sheets API를 사용 설정하고 OAuth 동의화면을 구성해야 합니다.
# GOOGLE_CLIENT_ID="000000000000-xxxxxxxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxx"
# 로컬: http://localhost:3000/api/google/callback  ·  배포: https://<도메인>/api/google/callback
# GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/google/callback"

# 선택: 저장 토큰 암호화 전용 키. 미설정 시 AUTH_SECRET에서 파생합니다.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# GOOGLE_TOKEN_KEY="change-me-generate-a-long-random-string"

# Vercel Cron 보호용 시크릿 — /api/cron/google-sync 의 Authorization 헤더 검증에 사용.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET="change-me-generate-a-long-random-string"

# 에이전트(Hermes) 연동 — 수집 메일의 "에이전트 분석"이 Discord 경유로 Hermes 두뇌에 질의.
# 미설정 시 메일 업무 등록 모달의 "에이전트 분석" 버튼이 비활성화됩니다.
# ※ 중요: Hermes가 앱이 보낸 메시지에 응답하려면, Hermes VPS 쪽 .env 의 DISCORD_ALLOWED_USERS 에
#   이 봇의 user id 가 포함돼야 합니다(봇이 보낸 "자기 메시지"는 기본적으로 무시됨).
# DISCORD_BOT_TOKEN="..."               # Discord 봇 토큰(Hermes 봇 것을 재사용 가능)
# DISCORD_AGENT_CHANNEL_ID="..."        # Hermes가 대기하는 채널 id. 없으면 DISCORD_HOME_CHANNEL / DISCORD_TEST_CHANNEL_ID 폴백
