// Second Brain + PMS — Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------
enum NodeType {
  SEMANTIC
  REFLECTIVE
  PROCEDURAL
  EPISODIC
  THESIS
  TOPIC
  ENTITY
  CLUSTER
}

enum EdgeType {
  SUPPORTS
  EXTENDS
  INSTANTIATES
  CONTRADICTS
  REFINES
  COMPOSES
  MENTIONS
  REQUIRES
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum Role {
  MEMBER
  ADMIN
}

// ----------------------------------------------------------------------------
// Auth / multi-tenant (reserved — nullable everywhere for now)
// ----------------------------------------------------------------------------
model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users    User[]
  notes    Note[]
  projects Project[]
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  image        String?
  // scrypt hash ("scrypt$N$r$p$<saltB64>$<hashB64>"). Nullable so SSO/legacy
  // users without a local password can still exist.
  passwordHash String?
  role         Role       @default(MEMBER)
  createdAt    DateTime   @default(now())
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id])

  authoredNotes Note[]    @relation("NoteAuthor")
  ownedProjects Project[] @relation("ProjectOwner")
  assignedTasks Task[]    @relation("TaskAssignee")
  sessions      Session[]
  googleAccount   GoogleAccount?
  oauthStates     OAuthState[]
  collectedMail   CollectedMail[]
  gmailLabelRules GmailLabelRule[]
}

// Server-side sessions: opaque random id stored in DB, signed (HMAC) into an
// httpOnly cookie. Lets us revoke on logout / role change instead of trusting a
// self-contained JWT.
model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ----------------------------------------------------------------------------
// Knowledge domain (graph nodes + edges)
// ----------------------------------------------------------------------------
model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  summary   String?
  type      NodeType @default(SEMANTIC)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId    String?
  author      User?      @relation("NoteAuthor", fields: [authorId], references: [id])
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id])

  // Stable per-document identity (usually the uploaded filename). All notes
  // created from one markdown import share it, so re-importing the same file
  // can delete-and-replace the previous version instead of duplicating it.
  sourceKey String?

  // How this record was created: "MAIL" | "KAKAO" | "MEETING" (=/import 문서).
  // Null for manually-created records. Rendered as a badge via lib/theme SOURCES.
  source String?

  tags NoteTag[]

  outgoingEdges Edge[] @relation("EdgeSource")
  incomingEdges Edge[] @relation("EdgeTarget")

  links NoteLink[]

  @@index([type])
  @@index([topicId])
  @@index([sourceKey])
}

model Tag {
  id    String  @id @default(cuid())
  name  String  @unique
  color String?

  notes NoteTag[]
}

model NoteTag {
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@index([tagId])
}

model Topic {
  id          String  @id @default(cuid())
  name        String
  description String?
  color       String?
  parentId    String?
  parent      Topic?  @relation("TopicHierarchy", fields: [parentId], references: [id])
  children    Topic[] @relation("TopicHierarchy")

  notes Note[]
}

model Edge {
  id        String   @id @default(cuid())
  sourceId  String
  targetId  String
  type      EdgeType @default(SUPPORTS)
  weight    Float    @default(1)
  note      String?
  createdAt DateTime @default(now())

  source Note @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Note @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
  @@index([sourceId])
  @@index([targetId])
}

// ----------------------------------------------------------------------------
// Project management domain
// ----------------------------------------------------------------------------
model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  color       String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  ownerId     String?
  owner       User?      @relation("ProjectOwner", fields: [ownerId], references: [id])
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  tasks Task[]
  links NoteLink[]

  // PMS submenu domain (ported from spmf)
  requirements     Requirement[]
  requirementSpecs RequirementSpec[]
  wbsItems         WBSItem[]
  pmsTasks         PmsTask[]
  deliverables     Deliverable[]
  staffDemands     StaffDemand[]
  staffMembers     StaffMember[]
  gmailLabelRules  GmailLabelRule[]
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  order       Float        @default(0)
  dueDate     DateTime?
  source      String?      // "MAIL" | "KAKAO" | "MEETING" | null(수동)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  links NoteLink[]

  @@index([projectId, status])
}

// ----------------------------------------------------------------------------
// Cross-domain link: attach a knowledge note to a project or task
// ----------------------------------------------------------------------------
model NoteLink {
  id        String   @id @default(cuid())
  noteId    String
  projectId String?
  taskId    String?
  relation  String?
  createdAt DateTime @default(now())

  note    Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([noteId])
  @@index([projectId])
  @@index([taskId])
}

// ----------------------------------------------------------------------------
// PMS submenu domain (ported from davidcho2026/spmf) — all scoped to a Project.
// spmf stored dates as free-form strings; here they are proper DateTime? so the
// import pipeline can bind extracted dates and the Gantt views can render them.
// WBS/PmsTask reuse the existing TaskStatus / TaskPriority enums.
// ----------------------------------------------------------------------------
enum RequirementSpecStatus {
  PENDING // 접수대기
  RECEIVED // 접수
  IN_PROGRESS // 진행
  DONE // 완료
  ON_HOLD // 보류
  REJECTED // 반려
}

enum ImportanceLevel {
  LOW // 하
  MEDIUM // 중
  HIGH // 상
}

// 요구사항 정의 (spmf: 과업 요구사항 / requirements-def)
model Requirement {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sortOrder   Int      @default(0)
  category    String   @default("기능")
  classif     String?
  rfpNo       String?
  subNo       String?
  name        String
  subName     String?
  detail      String?
  acceptance  String   @default("수용")
  output      String?
  // Date fields added on top of spmf so imported dates land here directly.
  requestDate DateTime?
  dueDate     DateTime?
  targetDate  DateTime?
  updatedBy   String?
  source      String?  // "MAIL" | "KAKAO" | "MEETING" | null(수동)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId, sortOrder])
}

// 요구사항 명세서 (spmf: requirements / RequirementSpec)
model RequirementSpec {
  id          String                @id @default(cuid())
  projectId   String
  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sortOrder   Int                   @default(0)
  iaId        String?
  systemType  String                @default("선택")
  status      RequirementSpecStatus @default(PENDING)
  menuPath    String?
  name        String
  detail      String?
  review      String?
  confirmed   Boolean               @default(false)
  importance  ImportanceLevel       @default(MEDIUM)
  files       String?
  requester   String?
  receiver    String?
  requestDate DateTime?
  dueDate     DateTime?
  targetDate  DateTime?
  progress    Int                   @default(0)
  source      String?               // "MAIL" | "KAKAO" | "MEETING" | null(수동)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([projectId, sortOrder])
}

// WBS (일정/간트)
model WBSItem {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId      String?
  parent        WBSItem?     @relation("WBSHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      WBSItem[]    @relation("WBSHierarchy")
  code          String?
  name          String
  level         Int          @default(1)
  phase         String?
  assignee      String?
  priority      TaskPriority @default(MEDIUM)
  status        TaskStatus   @default(TODO)
  progress      Int          @default(0)
  startDate     DateTime?
  endDate       DateTime?
  planStartDate DateTime?
  planEndDate   DateTime?
  description   String?
  source        String?      // "MAIL" | "KAKAO" | "MEETING" | null(수동)
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([projectId, sortOrder])
}

// 업무 TASK (spmf: Task) — kept separate from the kanban `Task` model above.
model PmsTask {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code        String?
  name        String
  phase       String?
  assignee    String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  progress    Int          @default(0)
  startDate   DateTime?
  endDate     DateTime?
  description String?
  source      String?      // "MAIL" | "KAKAO" | "MEETING" | null(수동)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([projectId, sortOrder])
}

// 산출물 관리 (spmf: Deliverable)
model Deliverable {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sortOrder    Int      @default(0)
  name         String
  description  String?
  templateFile String?
  outputFile   String?
  outputLink   String?
  source       String?  // "MAIL" | "KAKAO" | "MEETING" | null(수동)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId, sortOrder])
}

// 소프트웨어 기술자 등급 (인력관리)
enum StaffGrade {
  JUNIOR // 초급
  INTERMEDIATE // 중급
  SENIOR // 고급
  EXPERT // 특급
}

// 요구 인력 (직무·등급별 요구 인원 계획)
model StaffDemand {
  id        String     @id @default(cuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sortOrder Int        @default(0)
  role      String // 직무 (PM, 개발, 디자인 등)
  grade     StaffGrade @default(INTERMEDIATE)
  headcount Int        @default(1) // 요구 인원
  note      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([projectId, sortOrder])
}

// 투입 인력 (실제 배정 인원)
model StaffMember {
  id         String     @id @default(cuid())
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sortOrder  Int        @default(0)
  name       String // 이름
  grade      StaffGrade @default(INTERMEDIATE)
  role       String? // 직무
  company    String? // 소속/회사
  allocation Int        @default(100) // 투입률(%)
  startDate  DateTime? // 참여 시작
  endDate    DateTime? // 참여 종료
  contact    String? // 연락처
  note       String? // 비고
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([projectId, sortOrder])
}

// ----------------------------------------------------------------------------
// 입찰(Bid) 도메인 — 나라장터에서 수집한 용역 입찰공고 (독립 도메인)
// (bidNtceNo, bidNtceOrd) 조합이 논리적 유일키. 재수집은 upsert로 중복 방지하되
// 사용자가 지정한 status/memo는 보존한다.
// ----------------------------------------------------------------------------
enum BidStatus {
  NEW // 신규 수집
  INTERESTED // 관심
  EXCLUDED // 제외
}

model BidNotice {
  id String @id @default(cuid())

  bidNtceNo         String // 공고번호
  bidNtceOrd        String  @default("000") // 공고차수 (실측 3자리 문자열)
  bidNtceNm         String // 공고명
  srvceDivNm        String? // 용역구분명
  cntrctCnclsMthdNm String? // 계약체결방법 (제한경쟁 등)

  ntceInsttNm String? // 공고기관명
  dminsttNm   String? // 수요기관명

  bidNtceDt DateTime? // 공고일시
  bidClseDt DateTime? // 입찰마감일시
  opengDt   DateTime? // 개찰일시

  presmptPrce  String? // 추정가격(원본 문자열)
  asignBdgtAmt String? // 배정예산금액(원본 문자열)

  bidNtceDtlUrl String? // 나라장터 상세 URL

  matchedKeywords String[] // 매칭된 회사 키워드 그룹 라벨
  status          BidStatus @default(NEW)
  memo            String? // 사내 메모

  // AI 적합도 판정(CompanyProfile 기준). 수집 직후 자동 산출. 재수집해도 status/memo처럼
  // 사용자·이전 판정은 보존(collectBids update 절에 넣지 않음). null이면 미판정.
  fitScore     Int? // 0~100 적합도(높을수록 회사 특성과 부합)
  fitReason    String? // 판정 근거(한 줄)
  fitRecommend Boolean? // 추천 여부(대략 fitScore>=70)
  fitAt        DateTime? // 판정 시각

  raw Json? // 원본 응답 아이템(디버깅/필드 보강용)

  collectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspaceId String?

  @@unique([bidNtceNo, bidNtceOrd])
  @@index([status])
  @@index([bidClseDt])
  @@index([bidNtceDt])
  @@index([fitScore])
}

// ----------------------------------------------------------------------------
// 회사 프로필 — 입찰공고 AI 적합도 판정의 단일 기준(SSOT). 워크스페이스당 1개라
// 싱글턴(id는 고정 "default")으로 두고 설정 화면(/settings/company)에서 ADMIN이 편집.
// profile* 필드는 Gemini systemInstruction에 주입되고, avoidKeywords는 AI 호출 전
// 프리필터(제목에 기피어가 있으면 자동 저점)로 토큰을 아낀다. OAuthClientConfig와
// 같은 고정 id 싱글턴 패턴.
// ----------------------------------------------------------------------------
model CompanyProfile {
  id String @id @default("default")

  businessArea String? // 사업영역(한 줄)
  strengths    String? // 주력 기술·역량(여러 줄)
  preferred    String? // 선호 사업유형
  avoided      String? // 기피 조건(서술)
  extraNotes   String? // 규모·실적·보유자격 등 자유 서술

  avoidKeywords String[] // 네거티브 키워드 — 공고명에 있으면 프리필터에서 저점 처리

  updatedBy String? // 마지막 수정 userId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------------------
// 구글 연동 (사용자별 OAuth 2.0) — Gmail 수집 · Calendar 내보내기 · Sheets 리포트
// 사용자당 구글 계정 1개(@unique userId). refresh/access 토큰은 평문 저장 금지 —
// AES-256-GCM 암호문(src/lib/oauth-crypto.ts)으로 저장한다. 접근 취소 시 REVOKED.
// ----------------------------------------------------------------------------
enum GoogleAccountStatus {
  CONNECTED // 정상 연결
  REVOKED // 구글에서 접근 취소됨(재연결 필요)
}

model GoogleAccount {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  googleEmail String? // 연결된 구글 계정(표시용)
  scope       String? // 부여된 스코프(공백 구분)

  accessTokenEnc  String? // AES-256-GCM 암호문(access token)
  refreshTokenEnc String // AES-256-GCM 암호문(refresh token, 필수)
  expiryDate      DateTime? // access token 만료 시각

  status GoogleAccountStatus @default(CONNECTED)

  gmailSyncedAt      DateTime? // 마지막 Gmail 수집 시각(표시용)
  gmailLastHistoryId String? // 향후 History API 고도화용 예약
  // (구버전 단일 설정 — 이제 GmailLabelRule(N개)로 대체. 미사용, 하위호환 위해 유지)
  gmailProjectId     String?
  gmailLabel         String?

  // 시나리오별 대상 리소스 식별자.
  sheetsSpreadsheetId String? // PMS 리포트 대상 스프레드시트
  calendarId          String? // 전용 "PMS 일정" 캘린더

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 마감일→캘린더 단방향 동기화의 멱등 매핑. (엔티티,날짜필드) 하나당 이벤트 1개.
model GoogleCalendarLink {
  id            String   @id @default(cuid())
  userId        String
  entityType    String // "TASK" | "WBS" | "PMS_TASK" | "REQUIREMENT" | "REQUIREMENT_SPEC" | "PROJECT"
  entityId      String
  dateField     String // "dueDate" | "endDate" | "targetDate" | "startDate" ...
  googleEventId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, entityType, entityId, dateField])
  @@index([userId])
}

// OAuth Authorization Code 흐름의 CSRF state. Session 모델과 동형으로, 불투명 랜덤
// id를 코드에서 생성해 저장하고 콜백에서 1회용으로 소비(조회 후 즉시 삭제)한다.
// 쿠키 대신 DB로 관리해 서버측 폐기/검증이 가능하다.
model OAuthState {
  id        String   @id // Google로 보내는 불투명 랜덤 state 토큰(코드 생성)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String   @default("google")
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt])
}

// 구글 OAuth "앱(클라이언트)" 자격증명 — 사용자별이 아니라 앱 전역 1행(provider PK).
// 모든 사용자가 이 한 앱을 공유하고, 사용자 구분은 GoogleAccount(사용자별 토큰)가 담당.
// ADMIN이 설정 화면에서 입력하며 client secret은 AES-256-GCM 암호문으로 저장한다.
// .env의 GOOGLE_* 는 이 행이 없을 때의 폴백으로만 쓰인다(config.ts).
model OAuthClientConfig {
  provider        String   @id // "google"
  clientId        String
  clientSecretEnc String // AES-256-GCM 암호문
  redirectUri     String
  updatedBy       String? // 마지막 수정 ADMIN userId
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Gmail에서 수집한 메일 — 사용자별로 격리(각자 자기 메일함). BidNotice와 같은
// "수집→선별" 도메인: (userId, messageId)가 유일키라 재수집은 upsert로 중복 방지하되
// 사용자가 지정한 status/memo/noteId는 보존한다. 필요 시 노트로 변환(noteId 연결).
enum CollectedMailStatus {
  NEW // 신규 수집
  READ // 확인함
  ARCHIVED // 보관/제외
}

model CollectedMail {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  messageId String // Gmail 메시지 id
  threadId  String?
  subject   String    @default("(제목 없음)")
  fromAddr  String    @default("")
  toAddr    String?
  snippet   String? // 미리보기(구글 제공)
  body      String    @default("") // 본문(text)
  internalDate DateTime? // 메일 수신 시각
  labels    String? // 매칭된 검색 키워드(참고)

  status    CollectedMailStatus @default(NEW)
  memo      String?
  noteId    String? // 노트로 변환한 경우 연결
  projectId String? // 노트 변환 시 연결할 프로젝트(수집 당시 규칙에서 결정)

  collectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, messageId])
  @@index([userId, status])
  @@index([userId, internalDate])
}

// Gmail 라벨 → 프로젝트 매핑 규칙(사용자당 N개). 수집 시 모든 규칙을 순회하며 각
// 라벨의 메일을 CollectedMail로 저장하고, 해당 규칙의 projectId를 메일에 심어
// 노트 변환 시 그 프로젝트로 연결한다. 한 사용자 안에서 라벨은 유일.
model GmailLabelRule {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@unique([userId, label])
  @@index([userId])
}
